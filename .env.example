# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password

# ─── GlitchTip ────────────────────────────────────────────────────────────────
# Valkey (Redis-совместимый) запускается автоматически, отдельных настроек не требует

# Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
GLITCHTIP_SECRET_KEY=change_me_random_50_char_string

# Domain without https:// — Caddy добавит TLS автоматически
GLITCHTIP_HOST=errors.example.com
# Полный URL для ссылок в письмах
GLITCHTIP_DOMAIN=https://errors.example.com

DEFAULT_FROM_EMAIL=noreply@example.com
# Для разработки: consolemail://
# Для SMTP: smtp://user:password@host:587?tls=true
EMAIL_URL=consolemail://

# false — запрещает публичную регистрацию
GLITCHTIP_ENABLE_OPEN_USER_REGISTRATION=false

# ─── Umami ────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
UMAMI_APP_SECRET=change_me_random_string

# Domain без https://
UMAMI_HOST=analytics.example.com
